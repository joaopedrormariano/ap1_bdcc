# ==========================================================================
# Exemplo de variáveis de ambiente. Copie para ".env" e ajuste os valores.
# NUNCA versione o arquivo .env real (ele está no .gitignore).
# ==========================================================================

# --- Django ---
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=troque-por-uma-chave-secreta-forte
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.elasticbeanstalk.com
# Em produção com https/domínio próprio, ajuste (com esquema):
DJANGO_CSRF_TRUSTED_ORIGINS=https://SEU-AMBIENTE.elasticbeanstalk.com

# --- Banco de dados ---
# Atalho para testar sem PostgreSQL local (use SOMENTE em dev):
USE_SQLITE=False
# PostgreSQL local (fallback quando RDS_* não está definido):
POSTGRES_DB=catalogo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
# Em produção no Elastic Beanstalk com RDS acoplado, estas variáveis são
# injetadas automaticamente (NÃO precisa defini-las no repositório):
#   RDS_DB_NAME, RDS_USERNAME, RDS_PASSWORD, RDS_HOSTNAME, RDS_PORT

# --- Armazenamento de mídia (AWS S3) ---
USE_S3=False
AWS_ACCESS_KEY_ID=sua-access-key
AWS_SECRET_ACCESS_KEY=sua-secret-key
AWS_STORAGE_BUCKET_NAME=seu-bucket-de-midia
AWS_S3_REGION_NAME=us-east-1
# True = URLs assinadas (bucket privado); False = URLs públicas diretas:
AWS_QUERYSTRING_AUTH=False

# --- Superusuário admin (root) ---
DJANGO_SUPERUSER_USERNAME=root
DJANGO_SUPERUSER_EMAIL=root@example.com
DJANGO_SUPERUSER_PASSWORD=troque-por-uma-senha-forte
